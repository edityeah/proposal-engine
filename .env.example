# ─────────────────────────────────────────────────────────────
# CG Proposal Engine — environment variables
# Copy to .env.local for local dev; set the same in Vercel project settings.
# ─────────────────────────────────────────────────────────────

# Neon Postgres (Vercel Marketplace → Neon → copy the pooled connection string)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Anthropic (server-side only — never exposed to the browser)
ANTHROPIC_API_KEY="sk-ant-..."

# OpenAI (for the OpenAI models in the Research chat picker)
OPENAI_API_KEY="sk-..."

# Gemini (Google AI Studio → "Get API key") — powers the Gemini models in the
# Research chat picker, the distill flow, and Gemini-model chat titles. Uses
# Google's OpenAI-compatible endpoint. Server-side only.
GEMINI_API_KEY="AIza..."
GEMINI_MODEL="gemini-2.0-flash"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-32-byte-base64"

# Google OAuth (Google Cloud Console → Credentials → OAuth 2.0 Client)
# Authorized redirect URI: https://<your-domain>/api/auth/callback/google
#                          http://localhost:3000/api/auth/callback/google (for dev)
AUTH_GOOGLE_ID="xxxx.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="GOCSPX-..."

# Org restriction — only emails on this domain may sign in
ALLOWED_EMAIL_DOMAIN="convegenius.ai"

# Vercel Blob (Vercel project → Storage → Blob → read/write token)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Liveblocks (real-time presence) — liveblocks.io → your project → API keys.
# Use the DEVELOPMENT *secret* key (sk_dev_...) locally; the production secret
# (sk_prod_...) goes in Vercel. Server-side only — never exposed to the browser.
# Presence is disabled (no-op) if this is unset.
LIVEBLOCKS_SECRET_KEY=""
